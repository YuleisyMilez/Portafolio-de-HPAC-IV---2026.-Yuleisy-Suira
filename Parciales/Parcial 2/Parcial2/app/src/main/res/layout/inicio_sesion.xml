<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/pinky"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¡Bienvenido a Chinos Café!"
        android:textSize="24sp"
        android:textStyle="bold" />

    <ImageView
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="18dp"
        android:src="@drawable/chinos_cafe_logo"
        />

    <TextView
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:paddingStart="6dp"
        android:text="Usuario:"
        android:textSize="16sp" />

    <EditText
        android:id="@+id/et_usuario"
        android:layout_width="250dp"
        android:layout_height="36dp"
        android:layout_marginTop="4dp"
        android:paddingStart="10dp"
        android:hint="Ingrese credencial de usuario"
        android:textSize="16sp"
        android:background="@drawable/bg_input"
        android:inputType="text"
        android:singleLine="true"/>

    <TextView
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingStart="6dp"
        android:text="Contraseña:"
        android:textSize="16sp" />

    <EditText
        android:id="@+id/et_contrasena"
        android:layout_width="250dp"
        android:layout_height="36dp"
        android:layout_marginTop="4dp"
        android:paddingStart="10dp"
        android:hint="Ingrese la contraseña"
        android:textSize="16sp"
        android:background="@drawable/bg_input"
        android:inputType="textPassword" />

    <Button
        android:id="@+id/btn_ingresar"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:backgroundTint="@color/mahogany"
        android:text="Ingresar"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>