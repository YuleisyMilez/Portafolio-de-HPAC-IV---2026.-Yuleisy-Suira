<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ce_background"
    android:fillViewport="true"
    tools:theme="@style/Theme.ChiriquiEats">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Añadir empresa"
            android:textColor="@color/ce_text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/input_ruc"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_input"
            android:hint="RUC"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/ce_text"
            android:textColorHint="@color/ce_muted" />

        <EditText
            android:id="@+id/input_nombre"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Nombre"
            android:inputType="textCapWords"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/ce_text"
            android:textColorHint="@color/ce_muted" />

        <EditText
            android:id="@+id/input_direccion"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Dirección"
            android:inputType="textPostalAddress"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/ce_text"
            android:textColorHint="@color/ce_muted" />

        <EditText
            android:id="@+id/input_telefono"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Teléfono"
            android:inputType="phone"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/ce_text"
            android:textColorHint="@color/ce_muted" />

        <EditText
            android:id="@+id/input_correo"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Correo"
            android:inputType="textEmailAddress"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/ce_text"
            android:textColorHint="@color/ce_muted" />

        <Spinner
            android:id="@+id/spinner_categoria_empresa"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_selector"
            android:paddingStart="14dp"
            android:paddingEnd="14dp" />

        <Button
            android:id="@+id/button_submit_empresa"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="22dp"
            android:backgroundTint="@color/ce_green"
            android:text="Añadir"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
