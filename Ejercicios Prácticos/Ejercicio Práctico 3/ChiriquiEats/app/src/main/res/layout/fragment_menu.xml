<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ce_background"
    android:orientation="vertical"
    android:padding="20dp"
    tools:theme="@style/Theme.ChiriquiEats">

    <Spinner
        android:id="@+id/spinner_empresa_menu"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="@drawable/bg_selector"
        android:paddingStart="14dp"
        android:paddingEnd="14dp" />

    <FrameLayout
        android:id="@+id/menu_table_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:layout_weight="1"
        android:background="@drawable/bg_table_placeholder" />

    <Button
        android:id="@+id/button_add_menu"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="18dp"
        android:backgroundTint="@color/ce_green"
        android:text="Añadir menú"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
