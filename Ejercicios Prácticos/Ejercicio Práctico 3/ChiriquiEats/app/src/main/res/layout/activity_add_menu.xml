<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ce_background"
    android:fillViewport="true"
    tools:theme="@style/Theme.ChiriquiEats">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Añadir menú"
            android:textColor="@color/ce_text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinner_add_menu_empresa"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_selector"
            android:paddingStart="14dp"
            android:paddingEnd="14dp" />

        <EditText
            android:id="@+id/input_codigo_menu"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Código de menú"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/ce_text"
            android:textColorHint="@color/ce_muted" />

        <EditText
            android:id="@+id/input_nombre_menu"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Nombre de menú"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/ce_text"
            android:textColorHint="@color/ce_muted" />

        <EditText
            android:id="@+id/input_contenido_menu"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:gravity="top|start"
            android:hint="Contenido"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="6"
            android:paddingStart="14dp"
            android:paddingTop="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="14dp"
            android:textColor="@color/ce_text"
            android:textColorHint="@color/ce_muted" />

        <EditText
            android:id="@+id/input_precio_menu"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Precio"
            android:inputType="numberDecimal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/ce_text"
            android:textColorHint="@color/ce_muted" />

        <Button
            android:id="@+id/button_submit_menu"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="22dp"
            android:backgroundTint="@color/ce_green"
            android:text="Añadir"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
